<div class="container mt-5">

    <div class="card shadow-lg border-0">

        <div class="card-body">

            <h2 class="fw-bold mb-4">
                Create Assessment
            </h2>

            <form method="post">

                <div class="mb-3">

                    <label class="form-label">
                        Assessment Name
                    </label>

                    <input type="text"
                           name="name"
                           class="form-control"
                           required />

                </div>

                <button class="btn btn-dark">
                    Create
                </button>

            </form>

        </div>

    </div>

</div>