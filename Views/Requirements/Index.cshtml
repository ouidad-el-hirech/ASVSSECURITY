@model IEnumerable<ASVSSECURITYAUDITOR.Core.Entities.ASVSRequirement>

<div class="container mt-5">

    <div class="d-flex justify-content-between mb-4">
        <h2>OWASP ASVS Requirements</h2>

        <a class="btn btn-dark"
           href="/Admin/Import">
            Import CSV
        </a>
    </div>

    <!-- 🔍 SEARCH FORM (AJOUTÉ) -->
    <form method="get"
          class="row g-3 mb-4">

        <div class="col-md-5">
            <input type="text"
                   name="search"
                   class="form-control"
                   placeholder="Search requirements..." />
        </div>

        <div class="col-md-4">
            <select name="chapter"
                    class="form-select">

                <option value="">
                    All Chapters
                </option>

                @foreach(var chapter in ViewBag.Chapters)
                {
                    <option value="@chapter">
                        @chapter
                    </option>
                }

            </select>
        </div>

        <div class="col-md-3">
            <button class="btn btn-dark w-100">
                Search
            </button>
        </div>

    </form>

    <div class="card shadow-lg">

        <div class="card-body">

            <table class="table table-hover">

                <thead class="table-dark">
                    <tr>
                        <th>Code</th>
                        <th>Chapter</th>
                        <th>Title</th>
                        <th>Level</th>
                        <th>Actions</th> <!-- AJOUTÉ -->
                    </tr>
                </thead>

                <tbody>

                @foreach(var item in Model)
                {
                    <tr>
                        <td>@item.RequirementCode</td>
                        <td>@item.Chapter</td>
                        <td>@item.Title</td>
                        <td>@item.Level</td>

                        <!-- ACTION BUTTONS (MODIFIÉ) -->
                        <td class="d-flex gap-2">

                            <a href="/Requirements/Details/@item.Id"
                               class="btn btn-sm btn-outline-dark">
                                Details
                            </a>

                            <a href="/Requirements/Edit/@item.Id"
                               class="btn btn-sm btn-outline-primary">
                                Edit
                            </a>

                            <a href="/Requirements/Delete/@item.Id"
                               class="btn btn-sm btn-outline-danger">
                                Delete
                            </a>

                        </td>

                    </tr>
                }

                </tbody>

            </table>

        </div>

    </div>

</div>